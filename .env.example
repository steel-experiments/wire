STEEL_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Z.ai API key (GLM models via the GLM Coding Plan)
ZAI_API_KEY=

# LLM provider: openai | anthropic | zai
# With multiple API keys set, Wire picks the first of openai, anthropic, zai;
# set this to choose the default explicitly.
WIRE_PROVIDER=

# LLM model id (e.g. gpt-5.4-mini, claude-sonnet-4-6, glm-4.7)
WIRE_MODEL=

# LLM API base URL override (e.g. an Anthropic-compatible proxy)
WIRE_BASE_URL=

# OpenAI reasoning effort (reasoning models only): none | low | medium | high | xhigh
# "none" omits the field; leave empty to use the model's default. Ignored by non-reasoning models.
OPENAI_REASONING_EFFORT=

# Anthropic reasoning effort (extended thinking): low | medium | high | xhigh | max
# Leave empty to disable extended thinking. "high" is equivalent to not setting the parameter.
ANTHROPIC_REASONING_EFFORT=

# Z.ai reasoning effort (extended thinking on GLM models): low | medium | high | xhigh | max
# Leave empty to disable extended thinking.
ZAI_REASONING_EFFORT=
