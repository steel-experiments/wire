{
  "name": "wire",
  "version": "0.1.0",
  "private": true,
  "description": "The zero-weight browser agent.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "wire": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/agent/runtime.js",
    "./types": "./dist/shared/types.js",
    "./browser": "./dist/browser/bridge.js",
    "./providers/steel": "./dist/providers/browser/steel.js",
    "./providers/openai": "./dist/providers/llm/openai.js",
    "./policy": "./dist/policy/engine.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "pnpm run typecheck && pnpm run test",
    "lint": "pnpm run typecheck",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "metrics": "node scripts/metrics.mjs",
    "emit-schema": "tsx benchmarks/emit-schema.ts",
    "compare": "tsx benchmarks/compare/run-compare.ts"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
